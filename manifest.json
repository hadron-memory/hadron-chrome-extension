{
  "manifest_version": 3,
  "name": "Hadron Chrome Extension",
  "version": "0.1.0",
  "description": "Send the current page's URL or full HTML to Hadron as a node, optionally processed by a Hadron App task.",
  "minimum_chrome_version": "116",
  "key": "",
  "permissions": ["identity", "storage", "activeTab", "scripting"],
  "host_permissions": ["https://srv.hadronmemory.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Hadron Chrome Extension",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
